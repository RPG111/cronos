rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fan Zones — cualquiera puede leer, nadie puede escribir desde el cliente
    match /wc2026_fanzones/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Usuarios — solo el propio usuario puede leer y escribir sus datos
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Favoritos del usuario
    match /users/{userId}/savedFanZones/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Restaurant leads — cualquiera puede crear, nadie puede leer desde cliente
    match /restaurant_leads/{document=**} {
      allow create: if true;
      allow read, write: if false;
    }

    // Teams — solo lectura pública
    match /teams/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Todo lo demás — denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
