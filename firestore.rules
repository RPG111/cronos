rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fan Zones del Mundial — lectura pública, escritura solo admins
    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        'rpqa7pCNNhTPgQSosITBpuqiacF2',
        '0WZdp4lN16hA3wkmaP8L6X9Hg7j1',
        'zn5mQWpTmLZRcoxbEUOADTUvEy62'
      ];
    }

    match /wc2026_fanzones/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Eventos deportivos — lectura pública
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;

      // Asistentes — solo usuarios autenticados pueden escribir su propio registro
      match /attendees/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Picks/quinielas — solo el propio usuario
      match /picks/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Usuarios — solo el propio usuario
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Fan zones guardadas
      match /savedFanZones/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Teams — solo lectura pública
    match /teams/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Leads de restaurantes — cualquiera puede crear (nombre correcto)
    match /leads_restaurants/{document=**} {
      allow create: if true;
      allow read, write: if false;
    }

    // Bookings — solo usuarios autenticados
    match /bookings/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Todo lo demás — denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
